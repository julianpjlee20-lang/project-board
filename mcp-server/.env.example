# Uphouse Dashboard API token
# Get this from your dashboard settings or use your existing pb_... token
UPHOUSE_API_TOKEN=pb_your_token_here

# Optional: override if using a different dashboard URL
# UPHOUSE_BASE_URL=https://dashboard.uphousetw.com

# Secret token to protect your MCP endpoint
# Any AI tool connecting must send: Authorization: Bearer <this value>
MCP_SECRET_TOKEN=your_strong_secret_here

# Transport mode: http (for Zeabur/remote) or stdio (for local Claude Desktop)
TRANSPORT=http

# Port (Zeabur sets this automatically)
PORT=3000
